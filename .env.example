ARIA2_RPC_URL=http://127.0.0.1:6800/jsonrpc
ARIA2_TOKEN=your-aria2-rpc-secret
KODI_RPC_URL=http://127.0.0.1:8080/jsonrpc
KODI_USER=kodi
KODI_PASS=your-kodi-password
DOWNLOAD_DIR=/home/you/Downloads
# Optional override; by default Interlace uses its Python environment's yt-dlp module.
YT_DLP_PATH=
STREAM_RESOLVE_TIMEOUT=30
# Optional override; otherwise Interlace uses system ffmpeg or its local runtime.
FFMPEG_PATH=
FFMPEG_RUNTIME_DIR=/home/you/Interlace/backend/.runtime/ffmpeg
STREAM_RELAY_BASE_URL=http://127.0.0.1:8000
STREAM_RELAY_TTL=60
CONSOLE_HOST=0.0.0.0
CONSOLE_PORT=8000
